local OldNC
OldNC = hookmetamethod(game, "__namecall", function(self, ...)
    local m = getnamecallmethod()
    if m == "Kick" and self == LocalPlayer then return end
    if m == "FireServer" then
        local ok, n = pcall(function() return self.Name:lower() end)
        if ok and (n:find("kick") or n:find("ban") or n:find("report") or n:find("cheat")) then return end
    end
    if m == "InvokeServer" then
        local ok, n = pcall(function() return self.Name:lower() end)
        if ok and (n:find("kick") or n:find("ban")) then return end
    end
    return OldNC(self, ...)
end)

local OldIndex
OldIndex = hookmetamethod(game, "__index", function(self, key)
    if tostring(key):lower() == "kick" and self == LocalPlayer then
        return function() end
    end
    return OldIndex(self, key)
end)

