-- ============================================
-- ANTI KICK & BAN
-- ============================================
local OldNC
OldNC = hookmetamethod(game, "__namecall", function(self, ...)
    local m = getnamecallmethod()
    if m == "Kick" and self == LocalPlayer then return end
    if m == "FireServer" then
        local ok, n = pcall(function() return self.Name:lower() end)
        if ok and (n:find("kick") or n:find("ban") or n:find("report")) then return end
    end
    return OldNC(self, ...)
end)

-- ============================================
-- REMOVE LAVA
-- ============================================
local LavaNames = {"Lavas","Lava","lavas","lava","LAVA","LAVAS"}

local function NukePart(part)
    pcall(function()
        part.CanTouch = false; part.CanCollide = false; part.Transparency = 1
        for _, c in pairs(part:GetChildren()) do
            if c.ClassName == "TouchTransmitter" then c:Destroy() end
        end
        for _, s in pairs(part:GetDescendants()) do
            if s:IsA("Script") or s:IsA("LocalScript") then s.Disabled = true end
        end
    end)
end

local function NukeFolder(folder)
    pcall(function()
        for _, child in pairs(folder:GetChildren()) do
            if child:IsA("BasePart") or child:IsA("MeshPart") or child:IsA("UnionOperation") then
                NukePart(child)
            elseif child:IsA("Folder") or child:IsA("Model") then
                for _, sub in pairs(child:GetDescendants()) do
                    if sub:IsA("BasePart") or sub:IsA("MeshPart") or sub:IsA("UnionOperation") then NukePart(sub) end
                end
            end
        end
    end)
end

local function ScanLava()
    for _, n in ipairs(LavaNames) do
        local f = workspace:FindFirstChild(n)
        if f then NukeFolder(f) end
    end
    for _, obj in pairs(workspace:GetDescendants()) do
        local ln = obj.Name:lower()
        if (ln=="lava" or ln=="lavas") and (obj:IsA("Folder") or obj:IsA("Model")) then NukeFolder(obj) end
        if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
            local pn = obj.Parent and obj.Parent.Name:lower() or ""
            if pn=="lava" or pn=="lavas" then NukePart(obj) end
        end
    end
end

task.spawn(function()
    while true do
        task.wait(0.8)
        if State.RemoveLava then ScanLava() end
    end
end)

