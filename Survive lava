-- AUTO COLLECT RARITY BRAINROT
-- TP ke posisi brainrot lalu balik
-- ============================================
local RarityFolders = {"Godly","Legendary","Mythic","Secret","Epic","Rare"}

local function GetBrainrots()
    local list = {}
    for _, fname in ipairs(RarityFolders) do
        local folder = workspace:FindFirstChild(fname, true)
        if folder then
            for _, model in ipairs(folder:GetChildren()) do
                if model:IsA("Model") then
                    local root = model:FindFirstChild("HumanoidRootPart")
                        or model:FindFirstChildWhichIsA("BasePart")
                    if root then
                        table.insert(list, {model=model, part=root, rarity=fname})
                    end
                end
            end
        end
    end
    return list
end

local autoThread = nil

local function StartAutoCollect()
    autoThread = task.spawn(function()
        while State.AutoRarity do
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local brainrots = GetBrainrots()
                if #brainrots > 0 then
                    for _, data in ipairs(brainrots) do
                        if not State.AutoRarity then break end
                        -- TP ke brainrot
                        pcall(function()
                            root.CFrame = data.part.CFrame + Vector3.new(0, 3, 0)
                        end)
                        task.wait(0.5) -- tunggu trigger collect
                    end
                end
            end
            task.wait(1) -- jeda antar scan
        end
    end)
end

