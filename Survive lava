local function MakeToggle(label,yPos,cb)
    local Btn=Instance.new("TextButton",CF)
    Btn.Size=UDim2.new(1,-20,0,38); Btn.Position=UDim2.new(0,10,0,yPos)
    Btn.BackgroundColor3=Color3.fromRGB(22,22,30); Btn.BorderSizePixel=0
    Btn.Font=Enum.Font.GothamSemibold; Btn.TextSize=12
    Btn.TextColor3=Color3.fromRGB(200,200,200)
    Btn.Text="⬜  "..label.."  [OFF]"; Btn.TextXAlignment=Enum.TextXAlignment.Left
    Instance.new("UICorner",Btn).CornerRadius=UDim.new(0,7)
    local Pad=Instance.new("UIPadding",Btn); Pad.PaddingLeft=UDim.new(0,10)
    local active=false
    Btn.MouseButton1Click:Connect(function()
        active=not active
        if active then
            Btn.BackgroundColor3=Color3.fromRGB(255,65,0)
            Btn.TextColor3=Color3.fromRGB(255,255,255)
            Btn.Text="✅  "..label.."  [ON]"
        else
            Btn.BackgroundColor3=Color3.fromRGB(22,22,30)
            Btn.TextColor3=Color3.fromRGB(200,200,200)
            Btn.Text="⬜  "..label.."  [OFF]"
        end
        cb(active)
    end)
end

